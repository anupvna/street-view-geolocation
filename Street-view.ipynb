      "source": [
        "**Cell 8: Ensemble and Hard Grid Snapping**\n",
        "\n",
        "Combines predictions from two different models (Large and Base) via weighted averaging and aggressively snaps the coordinates to the nearest training road point within the predicted state."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "TvA4vReNqOBs"
      },
      "outputs": [],
      "source": [
        "df_a = pd.read_csv(\"submission_project2_tta_large.csv\")\n",
        "df_b = pd.read_csv(\"submission_project2_tta.csv\")\n",
        "train_df = pd.read_csv(TRAIN_CSV)\n",
        "\n",
        "w_a, w_b = 0.70, 0.30\n",
        "df_final = df_a.copy()\n",
        "df_final[\"predicted_latitude\"] = (df_a[\"predicted_latitude\"] * w_a) + (df_b[\"predicted_latitude\"] * w_b)\n",
        "df_final[\"predicted_longitude\"] = (df_a[\"predicted_longitude\"] * w_a) + (df_b[\"predicted_longitude\"] * w_b)\n",
        "df_final[\"predicted_state_idx_1\"] = df_a[\"predicted_state_idx_1\"]\n",
        "\n",
        "new_lats = df_final[\"predicted_latitude\"].values.copy()\n",
        "new_lons = df_final[\"predicted_longitude\"].values.copy()\n",
        "state_preds = df_final[\"predicted_state_idx_1\"].values\n",
        "\n",
        "for s_idx in range(50):\n",
        "    train_subset = train_df[train_df[\"state_idx\"] == s_idx]\n",
        "    if len(train_subset) == 0: continue\n",
        "    mask = (state_preds == s_idx)\n",
        "    if not np.any(mask): continue\n",
        "    t_coords = train_subset[[\"latitude\", \"longitude\"]].values\n",
        "    p_coords = df_final.loc[mask, [\"predicted_latitude\", \"predicted_longitude\"]].values\n",
        "    nbrs = NearestNeighbors(n_neighbors=1).fit(t_coords)\n",
        "    _, indices = nbrs.kneighbors(p_coords)\n",
        "    snapped = t_coords[indices.flatten()]\n",
        "    new_lats[mask] = snapped[:, 0]\n",
        "    new_lons[mask] = snapped[:, 1]\n",
        "\n",
        "df_final[\"predicted_latitude\"] = new_lats\n",
        "df_final[\"predicted_longitude\"] = new_lons\n",
        "df_final.to_csv(\"submission.csv\", index=False)"
      ]
    }
