      "source": [
        "**Cell 4: Model Architectures (DINOv3 and ConvNeXt)**\n",
        "\n",
        "Contains the definition of the Vision Transformer (DINOv3) and ConvNeXt V2 encoders, combined with a Transformer fusion layer to process the four directional views."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "xmIAYb61qK8x"
      },
      "outputs": [],
      "source": [
        "class DinoV3Encoder(nn.Module):\n",
        "    def __init__(self, model_id: str, hf_token: str):\n",
        "        super().__init__()\n",
        "        self.model = AutoModel.from_pretrained(\n",
        "            model_id,\n",
        "            token=hf_token,\n",
        "            trust_remote_code=True\n",
        "        )\n",
        "        self.embed_dim = self.model.config.hidden_size\n",
        "\n",
        "    def forward(self, x):\n",
        "        outputs = self.model(x)\n",
        "        return outputs.last_hidden_state[:, 0]\n",
        "\n",
        "class GeoDinoTransformer(nn.Module):\n",
        "    def __init__(self, model_id: str, hf_token: str, num_states: int = NUM_STATES):\n",
        "        super().__init__()\n",
        "        self.encoder = DinoV3Encoder(model_id, hf_token)\n",
        "        embed_dim = self.encoder.embed_dim\n",
        "        encoder_layer = nn.TransformerEncoderLayer(\n",
        "            d_model=embed_dim,\n",
        "            nhead=8,\n",
        "            batch_first=True,\n",
        "            dim_feedforward=embed_dim * 4,\n",
        "            dropout=0.3,\n",
        "            norm_first=True\n",
        "        )\n",
        "        self.fusion = nn.TransformerEncoder(encoder_layer, num_layers=2)\n",
        "        self.state_head = nn.Sequential(\n",
        "            nn.LayerNorm(embed_dim),\n",
        "            nn.Dropout(0.3),\n",
        "            nn.Linear(embed_dim, num_states)\n",
        "        )\n",
        "        self.gps_head = nn.Sequential(\n",
        "            nn.LayerNorm(embed_dim),\n",
        "            nn.Linear(embed_dim, 256),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.2),\n",
        "            nn.Linear(256, 2)\n",
        "        )\n",
        "\n",
        "    def forward(self, views):\n",
        "        B, V, C, H, W = views.shape\n",
        "        views_flat = views.view(B * V, C, H, W)\n",
        "        feats = self.encoder(views_flat)\n",
        "        feats = feats.reshape(B, V, -1)\n",
        "        fused_seq = self.fusion(feats)\n",
        "        global_feat = fused_seq.mean(dim=1)\n",
        "        state_logits = self.state_head(global_feat)\n",
        "        gps_norm = self.gps_head(global_feat)\n",
        "        return state_logits, gps_norm\n",
        "\n",
        "class GeoConvNextTransformer(nn.Module):\n",
        "    def __init__(self, model_name, num_states=50):\n",
        "        super().__init__()\n",
        "        self.backbone = timm.create_model(model_name, pretrained=True, num_classes=0)\n",
        "        self.embed_dim = self.backbone.num_features\n",
        "        encoder_layer = nn.TransformerEncoderLayer(\n",
        "            d_model=self.embed_dim,\n",
        "            nhead=8,\n",
        "            batch_first=True,\n",
        "            dim_feedforward=self.embed_dim * 4,\n",
        "            dropout=0.3,\n",
        "            norm_first=True\n",
        "        )\n",
        "        self.fusion = nn.TransformerEncoder(encoder_layer, num_layers=2)\n",
        "        self.state_head = nn.Sequential(\n",
        "            nn.LayerNorm(self.embed_dim),\n",
        "            nn.Dropout(0.3),\n",
        "            nn.Linear(self.embed_dim, num_states)\n",
        "        )\n",
        "        self.gps_head = nn.Sequential(\n",
        "            nn.LayerNorm(self.embed_dim),\n",
        "            nn.Linear(self.embed_dim, 256),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.2),\n",
        "            nn.Linear(256, 2)\n",
        "        )\n",
        "\n",
        "    def forward(self, views):\n",
        "        B, V, C, H, W = views.shape\n",
        "        x = views.view(B * V, C, H, W)\n",
        "        features = self.backbone(x)\n",
        "        features = features.view(B, V, -1)\n",
        "        fused_seq = self.fusion(features)\n",
        "        global_feat = fused_seq.mean(dim=1)\n",
        "        return self.state_head(global_feat), self.gps_head(global_feat)"
      ]
    },
    {
      "cell_type": "markdown",
