      },
      "source": [
        "**Cell 5: Training Helpers and Haversine Loss**\n",
        "\n",
        "Defines the specialized loss function based on the Haversine distance and provides helper functions to calculate the competition score during validation."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "F7Lm0OIgqOJu"
      },
      "outputs": [],
      "source": [
        "class HaversineLoss(nn.Module):\n",
        "    def __init__(self, r=6371.0):\n",
        "        super().__init__()\n",
        "        self.r = r\n",
        "\n",
        "    def forward(self, pred_gps_norm, true_gps_norm, lat_mean, lat_std, lon_mean, lon_std):\n",
        "        pred_lat = pred_gps_norm[:, 0] * lat_std + lat_mean\n",
        "        pred_lon = pred_gps_norm[:, 1] * lon_std + lon_mean\n",
        "        true_lat = true_gps_norm[:, 0] * lat_std + lat_mean\n",
        "        true_lon = true_gps_norm[:, 1] * lon_std + lon_mean\n",
        "        lat1, lon1, lat2, lon2 = map(torch.deg2rad, [pred_lat, pred_lon, true_lat, true_lon])\n",
        "        dlat = lat2 - lat1\n",
        "        dlon = lon2 - lon1\n",
        "        a = torch.sin(dlat/2)**2 + torch.cos(lat1) * torch.cos(lat2) * torch.sin(dlon/2)**2\n",
        "        c = 2 * torch.asin(torch.sqrt(a + 1e-6))\n",
        "        return (c * self.r).mean()\n",
        "\n",
        "def validate(model, loader):\n",
        "    model.eval()\n",
        "    total_loss = 0\n",
        "    correct_states = 0\n",
        "    total_samples = 0\n",
        "    criterion_cls = nn.CrossEntropyLoss()\n",
        "    criterion_gps = nn.MSELoss()\n",
        "    with torch.no_grad():\n",
        "        for imgs, states, gps in loader:\n",
        "            imgs, states, gps = imgs.to(device), states.to(device), gps.to(device)\n",
        "            with torch.cuda.amp.autocast():\n",
        "                logits, gps_pred = model(imgs)\n",
        "                loss = 0.7 * criterion_cls(logits, states) + 0.3 * criterion_gps(gps_pred, gps)\n",
        "\n",
        "            total_loss += loss.item() * imgs.size(0)\n",
        "            preds = torch.argmax(logits, dim=1)\n",
        "            correct_states += (preds == states).sum().item()\n",
        "            total_samples += imgs.size(0)\n",
        "    return total_loss / total_samples, correct_states / total_samples\n",
        "\n",
        "def haversine_km(lat1, lon1, lat2, lon2):\n",
        "    lat1, lon1, lat2, lon2 = map(np.radians, [lat1, lon1, lat2, lon2])\n",
        "    dlon = lon2 - lon1\n",
        "    dlat = lat2 - lat1\n",
        "    a = np.sin(dlat/2)**2 + np.cos(lat1) * np.cos(lat2) * np.sin(dlon/2)**2\n",
        "    c = 2 * np.arcsin(np.sqrt(a))\n",
        "    return c * 6371\n",
        "\n",
        "def calc_comp_score(pred_state_top5, true_state_idx, pred_lat, pred_lon, true_lat, true_lon):\n",
        "    weights = [1.0, 0.6, 0.4, 0.25, 0.15]\n",
        "    class_score = 0.0\n",
        "    if true_state_idx in pred_state_top5:\n",
        "        rank = list(pred_state_top5).index(true_state_idx)\n",
        "        class_score = weights[rank]\n",
        "    dist = haversine_km(pred_lat, pred_lon, true_lat, true_lon)\n",
        "    gps_score = max(0, 1 - (dist / 5000.0))\n",
        "    return class_score, gps_score"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "nQlB4bV0rCOx"
      },
      "source": [
        "**Cell 6: Training Loop with Differential Learning Rates**\n",
        "\n",
        "Executes the training process, applying lower learning rates to the backbone and higher rates to the fusion/heads. Includes validation and model checkpointing."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "ApfyDDsXqOHH"
      },
      "outputs": [],
      "source": [
        "model = GeoDinoTransformer(MODEL_ID, HF_TOKEN).to(device)\n",
        "param_groups = [\n",
        "    {'params': model.encoder.parameters(), 'lr': 1e-5, 'weight_decay': 0.05},\n",
        "    {'params': model.fusion.parameters(),  'lr': 2e-4, 'weight_decay': 1e-4},\n",
        "    {'params': model.state_head.parameters(), 'lr': 2e-4, 'weight_decay': 1e-4},\n",
        "    {'params': model.gps_head.parameters(),   'lr': 2e-4, 'weight_decay': 1e-4}\n",
        "]\n",
        "optimizer = torch.optim.AdamW(param_groups)\n",
        "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=NUM_EPOCHS)\n",
        "scaler = torch.cuda.amp.GradScaler() if device.type == \"cuda\" else None\n",
        "ce_criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
        "gps_criterion = HaversineLoss()\n",
        "\n",
        "best_comp_score = 0.0\n",
        "for epoch in range(1, NUM_EPOCHS + 1):\n",
        "    model.train()\n",
        "    total_loss = 0\n",
        "    for views, state_idx, gps_norm in train_loader:\n",
        "        views, state_idx, gps_norm = views.to(device), state_idx.to(device), gps_norm.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        with torch.cuda.amp.autocast(enabled=(scaler is not None)):\n",
        "            logits, gps_pred = model(views)\n",
        "            loss_cls = ce_criterion(logits, state_idx)\n",
        "            loss_gps = gps_criterion(gps_pred, gps_norm, lat_mean, lat_std, lon_mean, lon_std)\n",
        "            loss = 0.7 * loss_cls + 0.3 * (loss_gps / 1000.0)\n",
        "        if scaler:\n",
        "            scaler.scale(loss).backward()\n",
        "            scaler.step(optimizer)\n",
        "            scaler.update()\n",
        "        else:\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "    val_loss, val_score = validate(model, val_loader)\n",
        "    scheduler.step()\n",
        "    if val_score > best_comp_score:\n",
        "        best_comp_score = val_score\n",
        "        torch.save({\"model_state\": model.state_dict(), \"lat_mean\": lat_mean, \"lat_std\": lat_std, \"lon_mean\": lon_mean, \"lon_std\": lon_std, \"score\": best_comp_score}, \"best_geodino_grandmaster.pth\")"
      ]
    },
