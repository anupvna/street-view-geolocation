      "source": [
        "**Cell 7: Hybrid Inference and Test-Time Augmentation (TTA)**\n",
        "\n",
        "Loads a trained model (ConvNeXt or DINO) and performs inference on the test set using horizontal flips for Test-Time Augmentation to improve robustness."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "mBoVbZejqOEP"
      },
      "outputs": [],
      "source": [
        "ckpt = torch.load(\"best_convnext.pth\", map_location=device, weights_only=False)\n",
        "model.load_state_dict(ckpt[\"model_state\"])\n",
        "lat_mean, lat_std = ckpt[\"lat_mean\"], ckpt[\"lat_std\"]\n",
        "lon_mean, lon_std = ckpt[\"lon_mean\"], ckpt[\"lon_std\"]\n",
        "model.eval()\n",
        "\n",
        "all_top5, all_gps = [], []\n",
        "with torch.no_grad():\n",
        "    for views, sample_ids in test_loader:\n",
        "        views_flip = F.hflip(views)\n",
        "        views = views.to(device)\n",
        "        with torch.cuda.amp.autocast():\n",
        "            logits_1, gps_1 = model(views)\n",
        "        views_flip = views_flip.to(device)\n",
        "        with torch.cuda.amp.autocast():\n",
        "            logits_2, gps_2 = model(views_flip)\n",
        "        avg_logits = (logits_1 + logits_2) / 2.0\n",
        "        avg_gps_norm = (gps_1 + gps_2) / 2.0\n",
        "        probs = torch.softmax(avg_logits, dim=1)\n",
        "        top5_idx = probs.topk(5, dim=1).indices.cpu().numpy()\n",
        "        gps_norm = avg_gps_norm.cpu().numpy()\n",
        "        lat = gps_norm[:, 0] * lat_std + lat_mean\n",
        "        lon = gps_norm[:, 1] * lon_std + lon_mean\n",
        "        all_top5.append(top5_idx)\n",
        "        all_gps.append(np.stack([lat, lon], axis=1))\n",
        "\n",
        "all_top5 = np.concatenate(all_top5, axis=0)\n",
        "all_gps = np.concatenate(all_gps, axis=0)\n",
        "sub = test_df.copy()\n",
        "for k in range(5):\n",
        "    sub[f\"predicted_state_idx_{k+1}\"] = all_top5[:, k]\n",
        "sub[\"predicted_latitude\"] = all_gps[:, 0]\n",
        "sub[\"predicted_longitude\"] = all_gps[:, 1]\n",
        "sub.to_csv(\"submission_project2_convnext.csv\", index=False)"
      ]
    },
